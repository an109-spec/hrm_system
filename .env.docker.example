# === CẤU HÌNH HỆ THỐNG ===
FLASK_ENV=production
SECRET_KEY=change_me_secret
JWT_SECRET_KEY=change_me_jwt_secret
JWT_ACCESS_TOKEN_EXPIRES=3600

# === DATABASE (Sử dụng đồng bộ tên này) ===
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_database_password
DB_NAME=hrm_db

# === EMAIL (Sử dụng đồng bộ tên này) ===
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=change_me@example.com
MAIL_PASSWORD=change_me_mail_password
MAIL_DEFAULT_SENDER=change_me@example.com
MAIL_SUPPRESS_SEND=True

# === DỊCH VỤ KHÁC ===
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0
SOCKETIO_CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
JWT_COOKIE_CSRF_PROTECT=True